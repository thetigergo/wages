	<parameter name="RefKey" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["2023-000017"]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT 
  trabahante.bank_acct, 
  humane(trabahante.lastname, trabahante.firstname, trabahante.suffix, trabahante.midname),
  timebookque.netpay,
  advicepay.refdate,
  userlogon.userdescrp,
  signatures.mayorvice,
  signatures.accountant,
  signatures.designate2
FROM 
  psnl.trabahante JOIN pay.timebookque
  ON trabahante.uniqkey = timebookque.worker
  JOIN pay.advicepay
  ON advicepay.refkey = timebookque.advicekey
  JOIN public.userlogon
  ON userlogon.userid = advicepay.inputby
  CROSS JOIN public.signatures
WHERE
  (timebookque.advicekey = $P{RefKey}) AND
  (trabahante.bank_acct IS NOT NULL)
ORDER BY
  trabahante.bank_acct]]>
	</queryString>
