	<scriptlet name="Valudoy" class="jrscript.JRUserFunc">
		<scriptletDescription><![CDATA[]]></scriptletDescription>
	</scriptlet>
	<parameter name="CtrlNo" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["2025~007834"]]></defaultValueExpression>
	</parameter>
	<parameter name="HasATM" class="java.lang.Boolean" isForPrompting="false">
		<defaultValueExpression><![CDATA[true]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT
   humane(jobworker.lastname, jobworker.firstname, jobworker.suffix, jobworker.midname),
   jobworker.bank_acct,
   jobworker.jobdesc,  
   laborpaid.datefr,  
   laborpaid.dateto,
   laborpaid.frday,
   laborpaid.today,
   laborpaid.udays,  
   laborpaid.rate,  
   laborpaid.utime,  
   offices.office,  
   laborpaid.payfr,  
   laborpaid.payto,
   laborpaid.bunos,
   laborpaid.pag_ibig,
   laborpaid.sssprem,
   laborpaid.withtax,
   laborpaid.officer1,  
   laborpaid.officer2,  
   laborpaid.officer3,  
   laborpaid.designa1,  
   laborpaid.designa2,  
   laborpaid.designa3,
   laborpaid.certify,
   signatures.mayorvice,
   ((laborpaid.rate / 10560.0) * ((laborpaid.udays * 480.0) + laborpaid.utime))::numeric(9, 2) AS deduction,
   CASE WHEN (laborpaid.frday < 16 AND laborpaid.today < 16) OR (laborpaid.frday = 16 AND laborpaid.today > 16) THEN (laborpaid.rate / 2.0)::REAL ELSE laborpaid.rate END AS gross,
   suholan.typed
FROM  
   pay.suholan INNER JOIN pay.laborpaid 
   ON suholan.ctrlno = laborpaid.ctrlno
   INNER JOIN psnl.jobworker
   ON jobworker.uniqkey = laborpaid.worker
   JOIN psnl.offices
   ON laborpaid.opesina = offices.offcid
   CROSS JOIN public.signatures
WHERE
   (laborpaid.ctrlno = $P{CtrlNo})
ORDER BY  
   jobworker.lastname,
   jobworker.firstname,
   jobworker.midname]]>
	</queryString>
