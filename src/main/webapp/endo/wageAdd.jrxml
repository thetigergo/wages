	<variable name="Gross" class="java.lang.Float">
		<variableExpression><![CDATA[(($F{frday} < 16 & $F{today} < 16) | ($F{frday} == 16 & $F{today} > 16)) ? $F{rate}.floatValue() / 2.0F : $F{rate}.floatValue()]]></variableExpression>
	</variable>
	<variable name="Deduction" class="java.lang.Double">
		<variableExpression><![CDATA[Math.round(($F{rate}.floatValue() / 10560D * (($F{udays}.floatValue() * 480F) + $F{utime}.floatValue())) * 100D) * 0.01D]]></variableExpression>
	</variable>
	<variable name="NetAmount" class="java.lang.Double">
		<variableExpression><![CDATA[$F{gross} - $F{deduction} - $F{pag_ibig} - $F{sssprem} + $F{bunos} - $F{withtax}]]></variableExpression>
	</variable>
	<variable name="SubTaxes" class="java.lang.Double" calculation="Sum">
		<variableExpression><![CDATA[$F{withtax}]]></variableExpression>
	</variable>
	<variable name="SubGross" class="java.lang.Double" calculation="Sum">
		<variableExpression><![CDATA[$F{gross}]]></variableExpression>
	</variable>
	<variable name="SubLess" class="java.lang.Double" calculation="Sum">
		<variableExpression><![CDATA[$F{deduction}]]></variableExpression>
	</variable>
	<variable name="SubNet" class="java.lang.Double" calculation="Sum">
		<variableExpression><![CDATA[$V{NetAmount}]]></variableExpression>
	</variable>
	<variable name="SubPagibig" class="java.lang.Double" calculation="Sum">
		<variableExpression><![CDATA[$F{pag_ibig}]]></variableExpression>
	</variable>
	<variable name="SubSSSPrem" class="java.lang.Double" calculation="Sum">
		<variableExpression><![CDATA[$F{sssprem}]]></variableExpression>
	</variable>
	<variable name="SubAdd" class="java.lang.Double" calculation="Sum">
		<variableExpression><![CDATA[$F{bunos}]]></variableExpression>
	</variable>
