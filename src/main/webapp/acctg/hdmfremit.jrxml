<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="report name" pageWidth="842" pageHeight="595" orientation="Landscape" whenNoDataType="AllSectionsNoDetail" columnWidth="770" leftMargin="36" rightMargin="36" topMargin="36" bottomMargin="36" isFloatColumnFooter="true" uuid="5fcd160b-2cd1-4a79-91d8-295f4a3341ac">
	<property name="ireport.zoom" value="1.5"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<parameter name="Tuiga" class="java.lang.Integer" isForPrompting="false">
		<defaultValueExpression><![CDATA[2016]]></defaultValueExpression>
	</parameter>
	<parameter name="Bulan" class="java.lang.Integer" isForPrompting="false">
		<defaultValueExpression><![CDATA[11]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT 
  workers.lastname,
  workers.firstname,
  workers.midname, 
  SUM(wages.pag_ibig) AS pag_ibig,
  MIN(wages.dateto) AS dateto,
  (SELECT COUNT(*) FROM (
   SELECT
     workers.lastname,
     workers.firstname,
     workers.midname, 
     SUM(wages.pag_ibig)
   FROM
     pay.wages INNER JOIN jos.workers
     ON workers.uniqkey = wages.worker
   WHERE
     (DATE_PART('YEAR', wages.dateto) = $P{Tuiga}) AND 
     (DATE_PART('MONTH', wages.dateto) = $P{Bulan}) AND
     (wages.pag_ibig != 0.0)
   GROUP BY
     workers.lastname,
     workers.firstname,
     workers.midname
  ))::SMALLINT AS countz
FROM 
  pay.wages INNER JOIN jos.workers
  ON workers.uniqkey = wages.worker
WHERE 
  (DATE_PART('YEAR', wages.dateto) = $P{Tuiga}) AND 
  (DATE_PART('MONTH', wages.dateto) = $P{Bulan}) AND
  (wages.pag_ibig != 0.0)
GROUP BY
  workers.lastname,
  workers.firstname,
  workers.midname
ORDER BY
  workers.lastname,
  workers.firstname,
  workers.midname]]>
	</queryString>
	<field name="lastname" class="java.lang.String"/>
	<field name="firstname" class="java.lang.String"/>
	<field name="midname" class="java.lang.String"/>
	<field name="pag_ibig" class="java.lang.Double"/>
	<field name="dateto" class="java.sql.Date"/>
	<field name="countz" class="java.lang.Integer"/>
	<variable name="GrandTotal" class="java.lang.Double" calculation="Sum">
		<variableExpression><![CDATA[$F{pag_ibig}]]></variableExpression>
	</variable>
	<variable name="PageTotal" class="java.lang.Double" resetType="Page" calculation="Sum">
		<variableExpression><![CDATA[$F{pag_ibig}]]></variableExpression>
	</variable>
