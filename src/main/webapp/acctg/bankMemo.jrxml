	<detail>
		<band height="100" splitType="Stretch">
			<textField>
				<reportElement x="0" y="0" width="523" height="100" uuid="27277a7e-0ea4-4a5a-9f3b-dafd44a029e0"/>
				<textElement textAlignment="Justified" markup="html">
					<font size="10"/>
				</textElement>
				<textFieldExpression><![CDATA["Please debit our Account <b><u>City Government of Surigao</u></b> Account No. <b><u>" + $F{acctno} + " / " + $F{funds} + "</u></b> the amount of <b>" + $P{REPORT_SCRIPTLET}.AmountInWord( new java.text.DecimalFormat("#,##0.00").format($F{totamt}).toString(), 02, "" ) + " (P" + new java.text.DecimalFormat("#,##0.00").format($F{totamt}) + ")</b> Account No. <b><u>See Attached Sheets</u></b> Representing: <b><u>Payroll of Job Order Employees.</u></b>" +
"<br/><br/>" +
"I/We declare under penalty of perjury that our co-depositor/s is/are still living. This also authorizes you to debit our account for the corresponding service charge."]]></textFieldExpression>
			</textField>
		</band>
	</detail>
