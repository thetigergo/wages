	<queryString>
		<![CDATA[SELECT
   advicepay.refkey,
   advicepay.entered,
   advicepay.refdate,
   advicepay.inputby,
   advicepay.totamt,
   advicepay.acctno,
   advicepay.funds,
   signatures.mayorvice,
   signatures.designate4,
   signatures.teniente,
   signatures.posicion
FROM
   pay.advicepay CROSS JOIN public.signatures
WHERE
   (refkey = $P{RefKey})]]>
	</queryString>
