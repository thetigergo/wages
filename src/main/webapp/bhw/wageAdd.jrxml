	<variable name="Gross" class="java.lang.Double">
		<variableExpression><![CDATA[$F{months} * $F{rate}]]></variableExpression>
	</variable>
	<variable name="NetAmount" class="java.lang.Double">
		<variableExpression><![CDATA[$V{Gross} + $F{bunos}]]></variableExpression>
	</variable>
	<variable name="SubGross" class="java.lang.Double" calculation="Sum">
		<variableExpression><![CDATA[$V{Gross}]]></variableExpression>
	</variable>
	<variable name="SubNet" class="java.lang.Double" calculation="Sum">
		<variableExpression><![CDATA[$V{NetAmount}]]></variableExpression>
	</variable>
	<variable name="TimeRoll" class="java.lang.String">
		<variableExpression><![CDATA[( $F{quarter}.equals( (short)01 )
    ?
       "1st Quarter"
    :
    ($F{quarter}.equals( (short)02 )
        ?
          "2nd Quarter"
        :
        ($F{quarter}.equals( (short)03 )
            ?
                "3rd Quarter"
            :
                "4th Quarter"
        )
    )
)]]></variableExpression>
	</variable>
	<variable name="SubBunos" class="java.lang.Double" calculation="Sum">
		<variableExpression><![CDATA[$F{bunos}]]></variableExpression>
	</variable>
