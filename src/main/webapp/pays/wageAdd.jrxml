				<textElement textAlignment="Justified">
					<font size="8"/>
				</textElement>
				<text><![CDATA[     2. I CERTIFY that this roll is correct, every person whose name appears hereon rendered service for the time and at the rates stated under my general supervision.]]></text>
			</staticText>
			<staticText>
				<reportElement x="666" y="20" width="230" height="74" uuid="9428f6fb-3989-42ac-a2a5-057ac7b69d58"/>
