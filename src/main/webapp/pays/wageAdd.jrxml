	<property name="com.jaspersoft.studio.data.defaultdataadapter" value="joborders"/>
	<property name="com.jaspersoft.studio.data.sql.tables" value=""/>
	<parameter name="CtrlNo" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["2024~006811"]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT
   humane(jobworker.lastname, jobworker.firstname, jobworker.suffix, jobworker.midname),
   jobworker.bank_acct,
   jobworker.jobdesc,  
   timebook.datefr,  
   timebook.dateto,  
   timebook.days,  
   timebook.rate,  
   timebook.utime,  
   projects.projtitle,  
   timebook.jobordno,  
   offices.office,  
   timebook.payfr,  
   timebook.payto,
   timebook.bunos,
   timebook.pag_ibig,
   timebook.sssprem,
   timebook.officer1,  
   timebook.officer2,  
   timebook.officer3,  
   timebook.designa1,  
   timebook.designa2,  
   timebook.designa3,
   timebook.certify,
   suholan.typed
FROM
   pay.suholan INNER JOIN pay.timebook 
   ON suholan.ctrlno = timebook.ctrlno
   INNER JOIN psnl.jobworker
   ON jobworker.uniqkey = timebook.worker  
   INNER JOIN cbo.projects  
   ON timebook.proyekto = projects.projid  
   INNER JOIN psnl.offices  
   ON timebook.opesina = offices.offcid  
WHERE
   (timebook.ctrlno = $P{CtrlNo})
ORDER BY  
   jobworker.lastname,
   jobworker.firstname,
   jobworker.midname]]>
	</queryString>
