	<variable name="Gross" class="java.lang.Double">
		<variableExpression><![CDATA[$F{days}.floatValue() * $F{rate}.doubleValue()]]></variableExpression>
	</variable>
	<variable name="Deduction" class="java.lang.Double">
		<variableExpression><![CDATA[Math.round(($F{rate}.floatValue() / 480D * $F{utime}.intValue()) * 100D) * 0.01D]]></variableExpression>
	</variable>
	<variable name="NetAmount" class="java.lang.Double">
		<variableExpression><![CDATA[($F{days}.floatValue() * $F{rate}.doubleValue()) - $V{Deduction} + $F{bunos}.doubleValue() - $F{pag_ibig} - $F{sssprem}]]></variableExpression>
	</variable>
	<variable name="SubGross" class="java.lang.Double" calculation="Sum">
		<variableExpression><![CDATA[$V{Gross}]]></variableExpression>
	</variable>
	<variable name="SubLess" class="java.lang.Double" calculation="Sum">
		<variableExpression><![CDATA[$V{Deduction}]]></variableExpression>
	</variable>
	<variable name="SubNet" class="java.lang.Double" calculation="Sum">
		<variableExpression><![CDATA[$V{NetAmount}]]></variableExpression>
	</variable>
	<variable name="SubAdd" class="java.lang.Double" calculation="Sum">
		<variableExpression><![CDATA[$F{bunos}]]></variableExpression>
	</variable>
	<variable name="SubPagibig" class="java.lang.Double" calculation="Sum">
		<variableExpression><![CDATA[$F{pag_ibig}]]></variableExpression>
	</variable>
	<variable name="SubSSSPrem" class="java.lang.Double" calculation="Sum">
		<variableExpression><![CDATA[$F{sssprem}]]></variableExpression>
	</variable>
